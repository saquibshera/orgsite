# ─────────────────────────────────────────────
#  Softstacks – Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Brevo (SendinBlue) API Key
# Get it from: https://app.brevo.com → Account → API Keys
BREVO_API_KEY=your_brevo_api_key_here

# The email address that RECEIVES notifications when a student submits
ADMIN_EMAIL=info@softstacks.in

# The display name shown in the "From" field of notification emails
ADMIN_NAME=Softstacks Admin

# The "From" email that Brevo will send notifications from
# Must be a verified sender in your Brevo account
FROM_EMAIL=no-reply@softstacks.in
FROM_NAME=Softstacks Technologies

# Port for the server (default: 3000)
PORT=3000
